# Auth callbacks and share links — route to JS redirect page that preserves hash + query params
/?type=invite /auth-redirect.html 200
/?type=recovery /auth-redirect.html 200
/?type=email_change /auth-redirect.html 200
/?type=signup /auth-redirect.html 200
/?share=:share /auth-redirect.html 200

# Device routing — mobile-first default
# Desktop UAs are explicitly matched; everything else (mobile, bots, crawlers) gets /m/.
# Client-side UA script in each index.html handles edge cases (e.g. iPad in desktop mode).
/ /d/ 302 User-Agent=Windows|Macintosh|X11
/ /m/ 302

# Clean /m and /d paths
/m /m/ 301
/d /d/ 301

# SPA fallbacks
/m/* /m/index.html 200
/d/* /d/index.html 200
